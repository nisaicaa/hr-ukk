{
  "name": "hr-ukk",
  "version": "1.0.0",
  "scripts": {
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "concurrently \"npm run dev:admin\" \"npm run dev:hr\" \"npm run dev:finance\" \"npm run dev:employee\" \"npm run dev:auth\"",
    "dev:admin": "cd frontend/apps/admin-frontend && npm run dev",
    "dev:hr": "cd frontend/apps/hr-frontend && npm run dev",
    "dev:finance": "cd frontend/apps/finance-frontend && npm run dev",
    "dev:employee": "cd frontend/apps/employee-frontend && npm run dev",
    "dev:auth": "cd frontend/apps/auth-frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev"
  },
  "dependencies": {
    "sweetalert2": "^11.26.18"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
