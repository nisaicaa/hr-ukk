{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "react": ["./node_modules/react"],
      "react-dom": ["./node_modules/react-dom"],
      "@types/react": ["./node_modules/@types/react"],
      "@types/react-dom": ["./node_modules/@types/react-dom"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
